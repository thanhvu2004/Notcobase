@page
@{
    ViewData["Title"] = "Schema Renderer";
}

<div id="schema-renderer-root"></div>

@section Scripts {
    <script>
        const token = localStorage.getItem("jwtToken");

        if (!token) {
            window.location.href = "/Login";
        }
    </script>
    <link rel="stylesheet" href="https://unpkg.com/antd@5/dist/reset.css" />
    <script crossorigin src="https://unpkg.com/react@18/umd/react.development.js"></script>
    <script crossorigin src="https://unpkg.com/react-dom@18/umd/react-dom.development.js"></script>
    <script src="https://unpkg.com/dayjs@1/dayjs.min.js"></script>
    <script src="https://unpkg.com/antd@5/dist/antd.min.js"></script>
    <script src="https://unpkg.com/zustand@4.5.0/umd/vanilla.production.js"></script>
    <script type="module" src="~/js/schemaRenderer/designer/DesignerDndKitBridge.js" asp-append-version="true"></script>
    <script src="~/js/schemaRenderer/api/ApiClient.js" asp-append-version="true"></script>
    <script src="~/js/shared/ReferenceField.js" asp-append-version="true"></script>
    <script src="~/js/shared/DynamicSelectField.js" asp-append-version="true"></script>
    <script src="~/js/schemaRenderer/core/SchemaUtils.js" asp-append-version="true"></script>
    <script src="~/js/schemaRenderer/core/BlockUtils.js" asp-append-version="true"></script>
    <script src="~/js/schemaRenderer/api/TablesApi.js" asp-append-version="true"></script>
    <script src="~/js/schemaRenderer/api/RecordsApi.js" asp-append-version="true"></script>
    <script src="~/js/schemaRenderer/core/ComponentRegistry.js" asp-append-version="true"></script>
    <script src="~/js/schemaRenderer/core/DecoratorRegistry.js" asp-append-version="true"></script>
    <script src="~/js/schemaRenderer/designer/DesignerStore.js" asp-append-version="true"></script>
    <script src="~/js/schemaRenderer/components/BlockComponents.js" asp-append-version="true"></script>
    <script src="~/js/schemaRenderer/renderer/SchemaRenderer.js" asp-append-version="true"></script>
    <script src="~/js/schemaRenderer/api/SchemaPagesApi.js" asp-append-version="true"></script>
    <script src="~/js/schemaRenderer/components/PropertyPanel.js" asp-append-version="true"></script>
    <script src="~/js/schemaRenderer/designer/SchemaDesignerApp.js" asp-append-version="true"></script>
}
